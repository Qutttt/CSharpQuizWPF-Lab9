<Window x:Class="CSharpQuizWPF.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="320" Width="350" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="txtRegUsername" Grid.Row="0" Margin="0,5" ToolTip="Имя"/>
        <PasswordBox x:Name="txtRegPassword" Grid.Row="1" Margin="0,5" ToolTip="Пароль"/>
        <PasswordBox x:Name="txtRegConfirm" Grid.Row="2" Margin="0,5" ToolTip="Подтверждение пароля"/>
        <Button x:Name="btnRegSubmit" Grid.Row="3" Content="Зарегистрироваться" Margin="0,10,0,5" Padding="8" Click="BtnRegSubmit_Click"/>
        <TextBlock x:Name="lblRegStatus" Grid.Row="4" Margin="0,5" TextWrapping="Wrap"/>
    </Grid>
</Window>