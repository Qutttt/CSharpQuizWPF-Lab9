<Window x:Class="CSharpQuizWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="280" Width="350" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Авторизация" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <TextBox x:Name="txtUsername" Grid.Row="1" Margin="0,5" Height="25" 
                 ToolTip="Имя пользователя" AutomationProperties.AutomationId="txtUsername"/>

        <PasswordBox x:Name="txtPassword" Grid.Row="2" Margin="0,5" Height="25" 
                     ToolTip="Пароль" AutomationProperties.AutomationId="txtPassword"/>

        <Button x:Name="btnLogin" Grid.Row="3" Content="Войти" Margin="0,10,0,5" 
                Padding="8" Height="30" Click="BtnLogin_Click" 
                AutomationProperties.AutomationId="btnLogin"/>

        <Button x:Name="btnRegister" Grid.Row="4" Content="Регистрация" Margin="0,5" 
                Padding="8" Height="30" Click="BtnRegister_Click"
                AutomationProperties.AutomationId="btnRegister"/>

        <TextBlock x:Name="lblError" Grid.Row="5" Foreground="Red" Margin="0,10,0,0" 
                   TextWrapping="Wrap" AutomationProperties.AutomationId="lblError"/>
    </Grid>
</Window>